{
  "name": "foxen/laravel-model-activity-log",
  "description": "A simple Laravel package to log model activity.",
  "type": "laravel-package",
  "license": "MIT",
  "authors": [
    {
      "name": "mrdth",
      "email": "mrdth@zeventien.org"
    }
  ],
  "require": {
    "php": "^8.3",
    "illuminate/support": "^11.0 || ^12.0",
    "illuminate/database": "^11.0 || ^12.0"
  },
  "require-dev": {
    "orchestra/testbench": "^9.0|^10.0",
    "pestphp/pest": "^3.0",
    "pestphp/pest-plugin-laravel": "^3.0",
    "laravel/pint": "^1.23"
  },
  "autoload": {
    "psr-4": {
      "Foxen\\LaravelModelActivityLog\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Foxen\\LaravelModelActivityLog\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Foxen\\LaravelModelActivityLog\\Providers\\ActivityLogServiceProvider"
      ]
    }
  },
  "scripts": {
    "test": "vendor/bin/pest",
    "test-coverage": "vendor/bin/pest --coverage",
    "format": "vendor/bin/pint"
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}
